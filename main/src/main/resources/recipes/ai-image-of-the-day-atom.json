{
  "startStepId": "cache",
  "resultContentType": "application/json",
  "steps": [
    {
      "id": "buildString",
      "type": "local:org.jraf.webpipes.main.dropbox.DropboxLatestImageStep",
      "configuration": {
        "folder": "/Trmnl/AI"
      }
    },
    {
      "id": "buildFeed",
      "type": "local:org.jraf.webpipes.main.dropbox.DropboxFeedStep"
    },
    {
      "id": "addAtomLink",
      "type": "local:org.jraf.webpipes.engine.step.core.CopyContextFieldStep",
      "configuration": {
        "sourceFieldName": "requestUrl",
        "targetFieldName": "atomLink"
      }
    },
    {
      "id": "atom",
      "type": "local:org.jraf.webpipes.atom.AtomStep",
      "configuration": {
        "atomTitle": "AI Picture of the Day",
        "atomDescription": "AI Picture of the Day",
        "atomEntriesAuthor": "BoD"
      }
    },
    {
      "id": "cachedChain",
      "type": "local:org.jraf.webpipes.engine.execute.StepChainExecutor",
      "configuration": {
        "chain": [
          "buildString",
          "buildFeed",
          "addAtomLink",
          "atom"
        ]
      }
    },
    {
      "id": "cache",
      "type": "local:org.jraf.webpipes.engine.step.core.CacheStep",
      "configuration": {
        "cachedStepId": "cachedChain",
        "maxAge": 86400
      }
    }
  ]
}
